# Offer builder — Resend (recommended on Vercel)
# Set RESEND_API_KEY in Vercel dashboard only — never commit the real key.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Sender address — must be a verified domain in Resend, or use onboarding@resend.dev for testing
FROM_EMAIL=onboarding@resend.dev

# Recipient for quote requests (fallback in code: kgdev@biuro.net)
TO_EMAIL=kgdev@biuro.net

# Fallback if Resend is not configured
# Create a form at https://formspree.io and paste the endpoint URL
FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx
